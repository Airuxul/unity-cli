{
  "name": "compile-recompile-cycle",
  "description": "Add/remove Assets script and compile 3x — simulates Unity domain reload after script churn (CONN-10 sync POST)",
  "steps": [
    {
      "name": "00_wait_editor",
      "waitProfile": "editor",
      "timeoutMs": 120000
    },
    {
      "name": "01_ping",
      "command": "ping",
      "expect": { "ok": true },
      "expectConnectorBuild": 40
    },
    {
      "name": "02_cleanup_stale_script",
      "deleteFile": {
        "path": "${UNITY_CMD_WORKSPACE}/Assets/_IntegrationTest_CompileRecompileCycle.cs"
      }
    },
    {
      "name": "03_baseline_compile",
      "command": "compile",
      "timeoutMs": 120000,
      "expect": { "ok": true }
    },
    {
      "name": "04_wait_after_baseline",
      "waitProfile": "editor",
      "timeoutMs": 120000
    },
    {
      "name": "05_recompile_script_churn",
      "repeat": 3,
      "steps": [
        {
          "name": "write_script",
          "writeFile": {
            "path": "${UNITY_CMD_WORKSPACE}/Assets/_IntegrationTest_CompileRecompileCycle.cs",
            "content": "// AUTO-GENERATED by compile-recompile-cycle — DO NOT COMMIT\nusing UnityEngine;\n\npublic sealed class _IntegrationTestCompileRecompileCycle : MonoBehaviour\n{\n}\n"
          }
        },
        {
          "name": "sleep_import",
          "sleepMs": 2000
        },
        {
          "name": "compile_after_add",
          "command": "compile",
          "timeoutMs": 120000,
          "expect": { "ok": true }
        },
        {
          "name": "wait_after_compile",
          "waitProfile": "editor",
          "timeoutMs": 120000
        },
        {
          "name": "ping_after_compile",
          "command": "ping",
          "expect": {
            "ok": true,
            "data": { "listener_running": true, "commands_ready": true }
          }
        },
        {
          "name": "delete_script",
          "deleteFile": {
            "path": "${UNITY_CMD_WORKSPACE}/Assets/_IntegrationTest_CompileRecompileCycle.cs"
          }
        },
        {
          "name": "sleep_reimport",
          "sleepMs": 2000
        },
        {
          "name": "compile_after_remove",
          "command": "compile",
          "timeoutMs": 120000,
          "expect": { "ok": true }
        },
        {
          "name": "wait_after_remove_compile",
          "waitProfile": "editor",
          "timeoutMs": 120000
        }
      ]
    },
    {
      "name": "06_final_ping",
      "command": "ping",
      "expect": {
        "ok": true,
        "data": { "listener_running": true, "commands_ready": true, "play_mode": "edit" }
      },
      "expectConnectorBuild": 40
    },
    {
      "name": "07_console_no_errors",
      "command": "console",
      "args": ["--type", "error", "--lines", "20"],
      "expect": { "ok": true, "dataHas": ["count", "entries"] }
    }
  ]
}
